{
  "name": "personal-portfolio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "GITHUB_REPOSITORY=${GITHUB_REPOSITORY:-jintong-art/portfolio} vite build && cp dist/index.html dist/404.html",
    "build:root": "env -u GITHUB_REPOSITORY vite build && cp dist/index.html dist/404.html",
    "build:gh": "npm run build",
    "preview": "GITHUB_REPOSITORY=${GITHUB_REPOSITORY:-jintong-art/portfolio} vite preview",
    "preview:root": "env -u GITHUB_REPOSITORY vite preview"
  },
  "dependencies": {
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.3",
    "vite": "^4.3.9"
  }
}
